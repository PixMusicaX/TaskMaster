// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id           String @id @default("me")
  xp           Int    @default(0)
  level        Int    @default(1)
  strength     Int    @default(0)
  intelligence Int    @default(0)
  wealth       Int    @default(0)
  vitality     Int    @default(0)
  charisma     Int    @default(0)
}

model Habit {
  id        String     @id @default(cuid())
  name      String
  icon      String?
  color     String?
  frequency Int[]      @default([0, 1, 2, 3, 4, 5, 6])
  archived  Boolean    @default(false)
  stat      String? // strength, intelligence, wealth, vitality, charisma
  streak    Int        @default(0)
  logs      HabitLog[]
  createdAt DateTime   @default(now())
}

model HabitLog {
  id        String  @id @default(cuid())
  habitId   String
  habit     Habit   @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      String // Format: YYYY-MM-DD
  completed Boolean @default(false)

  @@unique([habitId, date])
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  date      String   @unique // Format: YYYY-MM-DD
  mood      String   @default("neutral")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String?   @db.Text
  startTime    DateTime?
  endTime      DateTime?
  date         String // Format: YYYY-MM-DD
  type         String // "task" or "event"
  tier         String    @default("side") // side, main, epic
  stat         String? // strength, intelligence, wealth, vitality, charisma
  completed    Boolean   @default(false)
  notification Boolean   @default(false)
  createdAt    DateTime  @default(now())
}

model SmartMission {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  date        String   @unique // Format: YYYY-MM-DD
  completed   Boolean  @default(false)
  xpReward    Int      @default(25)
  stat        String   @default("charisma")
  quote       String?  @db.Text
  createdAt   DateTime @default(now())
}

model ReliefRecommendation {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  type          String? // movie, song, activity, food
  date          String   @unique // Format: YYYY-MM-DD
  completed     Boolean  @default(false)
  alt1Completed Boolean  @default(false)
  alt2Completed Boolean  @default(false)
  xpReward      Int      @default(5)
  stat          String   @default("charisma")
  location      String?
  weather       String?
  temp          String?
  alternatives  Json? // Store alternative suggestions
  createdAt     DateTime @default(now())
}
